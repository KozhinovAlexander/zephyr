config CORDIC_STM32
	bool "STM32 CORDIC driver"
	default y
	depends on DT_HAS_ST_STM32_CORDIC_ENABLED
	# select USE_STM32_LL_CORDIC
	help
	  Enable STM32 CORDIC driver. The CORDIC coprocessor is available
	  on STM32G4, STM32H5, STM32H7, STM32U5 series.
